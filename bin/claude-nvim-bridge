#!/bin/bash
# bin/claude-nvim-bridge

# 1. Read the JSON payload from Claude Code via stdin
PAYLOAD=$(cat)

# 2. Safely extract the tool name and file path using Python
TOOL_NAME=$(echo "$PAYLOAD" | python3 -c "import sys, json; print(json.load(sys.stdin).get('tool_name', ''))")
FILE_PATH=$(echo "$PAYLOAD" | python3 -c "import sys, json; print(json.load(sys.stdin).get('tool_input', {}).get('file_path', ''))")
FILE_PATH=$(realpath "$FILE_PATH")

# If it's not Edit or Write, allow it to continue normally
if [[ "$TOOL_NAME" != "Edit" && "$TOOL_NAME" != "Write" ]]; then
  exit 0
fi

# 3. Find the Neovim socket for this specific workspace

SOCKET=""

# Priority 1: Claude is running inside a Neovim terminal — use that instance directly
if [ -n "$NVIM_LISTEN_ADDRESS" ]; then
  SOCKET="$NVIM_LISTEN_ADDRESS"
elif [ -n "$NVIM" ]; then
  SOCKET="$NVIM"
fi

# Priority 2: Match by cwd — the most reliable cross-workspace strategy
if [ -z "$SOCKET" ]; then
  CLAUDE_CWD=$(echo "$PAYLOAD" | python3 -c "import sys, json; print(json.load(sys.stdin).get('cwd', ''))" 2>/dev/null)
  if [ -n "$CLAUDE_CWD" ]; then
    CWD_HASH=$(python3 -c "import hashlib, sys; print(hashlib.sha256(sys.argv[1].encode()).hexdigest()[:8])" "$CLAUDE_CWD" 2>/dev/null)
    CWD_FILE="/tmp/claude-nvim-cwd-${CWD_HASH}.txt"
    [ -f "$CWD_FILE" ] && SOCKET=$(cat "$CWD_FILE")
  fi
fi

# Priority 3: CMUX/tmux window-scoped file (legacy fallback)
if [ -z "$SOCKET" ]; then
  CMUX_ID="${CMUX_WINDOW_ID:-${TMUX_PANE:-default}}"
  SCOPED_FILE="/tmp/claude-nvim-server-${CMUX_ID}.txt"
  [ -f "$SCOPED_FILE" ] && SOCKET=$(cat "$SCOPED_FILE")
fi

# 4. Extract Claude's proposed code into a temporary file
NEW_CONTENT_FILE=$(mktemp)
echo "$PAYLOAD" | python3 -c "import sys, json; print(json.load(sys.stdin).get('tool_input', {}).get('new_string', ''))" >"$NEW_CONTENT_FILE"

# 5. Create a temporary status file for Neovim to write its decision to
STATUS_FILE=$(mktemp)

# 6. Send to running Neovim via RPC, or spawn a standalone reviewer if none is found
if [ -n "$SOCKET" ] && [ -S "$SOCKET" ]; then
  nvim --server "$SOCKET" --remote-expr "luaeval(\"require('claude-reviewer').start_review('$FILE_PATH', '$NEW_CONTENT_FILE', '$STATUS_FILE')\")" >/dev/null 2>&1
else
  # No running Neovim — show diff inline and prompt y/n in the terminal
  {
    echo ""
    echo "Claude wants to edit: $FILE_PATH"
    echo "────────────────────────────────────────"
    if [ -f "$FILE_PATH" ]; then
      if command -v delta >/dev/null 2>&1; then
        diff -u "$FILE_PATH" "$NEW_CONTENT_FILE" | delta
      else
        diff --color=always -u "$FILE_PATH" "$NEW_CONTENT_FILE"
      fi
    else
      cat "$NEW_CONTENT_FILE"
    fi
    echo "────────────────────────────────────────"
  } >/dev/tty 2>&1

  printf "Approve this edit? [y/N] " >/dev/tty
  read -r ANSWER </dev/tty

  if [[ "$ANSWER" =~ ^[Yy]$ ]]; then
    echo "0" >"$STATUS_FILE"
  else
    echo "2" >"$STATUS_FILE"
  fi
fi

# 7. Wait indefinitely for the user to approve or deny in Neovim
while [ ! -s "$STATUS_FILE" ]; do
  sleep 0.5
done

RESULT=$(cat "$STATUS_FILE")

# 8. Cleanup temp files
rm -f "$NEW_CONTENT_FILE" "$STATUS_FILE"

# 9. Read decision and respond directly to Claude Code's permission engine
if [ "$RESULT" = "2" ]; then
  echo '{"hookSpecificOutput": {"hookEventName": "PermissionRequest", "decision": {"behavior": "deny", "message": "Edit rejected by user in Neovim."}}}'
  exit 2
else
  echo '{"hookSpecificOutput": {"hookEventName": "PermissionRequest", "decision": {"behavior": "allow"}}}'
  exit 0
fi

exit 0
